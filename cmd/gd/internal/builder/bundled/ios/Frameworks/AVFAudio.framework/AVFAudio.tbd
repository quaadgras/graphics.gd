--- !tapi-tbd
tbd-version:  4
install-name: '/System/Library/Frameworks/AVFAudio.framework/AVFAudio'  # expected location for the implementation on IOS
targets:
 - arm64-ios
exports:
 - targets: [ arm64-ios ]
   symbols:
    - _AVSpeechUtteranceMinimumSpeechRate
    - _AVSpeechUtteranceMaximumSpeechRate
    - _AVSpeechUtteranceDefaultSpeechRate
    - _AVAudioSessionInterruptionTypeKey
    - _AVAudioSessionInterruptionNotification
    - _AVAudioSessionCategorySoloAmbient
    - _AVAudioSessionCategoryRecord
    - _AVAudioSessionCategoryPlayback
    - _AVAudioSessionCategoryPlayAndRecord
    - _AVAudioSessionCategoryMultiRoute
    - _AVAudioSessionCategoryAmbient
   objc-classes:
    - AVSpeechUtterance
    - AVSpeechSynthesizer
    - AVSpeechSynthesisVoice
    - AVAudioSession
    - AVAudioApplication
...
